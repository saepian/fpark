{
  "framework": "nextjs",
  "functions": {
    "app/api/cron/fetch-news/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/daily-pick/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/fetch-news",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/daily-pick",
      "schedule": "0 0 * * *"
    }
  ]
}
