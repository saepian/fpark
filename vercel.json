{
  "framework": "nextjs",
  "functions": {
    "app/api/cron/fetch-news/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/daily-pick/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/billing/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/stock-alerts/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/daily-alert-email/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/market-cache-warm/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/notifications-cleanup/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/virtual-account-renewal/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/fetch-news",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/daily-pick",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/billing",
      "schedule": "5 15 1 * *"
    },
    {
      "path": "/api/cron/stock-alerts",
      "schedule": "0,10,20,30,40,50 0-6 * * 1-5"
    },
    {
      "path": "/api/cron/daily-alert-email",
      "schedule": "45 6 * * 1-5"
    },
    {
      "path": "/api/cron/market-cache-warm",
      "schedule": "35 6 * * 1-5"
    },
    {
      "path": "/api/cron/notifications-cleanup",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/virtual-account-renewal",
      "schedule": "0 16 * * *"
    }
  ]
}
